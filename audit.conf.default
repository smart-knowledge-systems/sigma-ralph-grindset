# audit.conf.default — Sigma Ralph Grindset defaults
# Do not edit this file. Run `bun config` to save overrides to audit.conf.

# Project root — leave empty to auto-detect (parent directory in portable mode)
PROJECT_ROOT=""

# Directories to scan (relative to PROJECT_ROOT)
START_DIRS=("src")

# File extensions to audit (space-separated)
FILE_EXTENSIONS="ts tsx"

# Directories to exclude from auditing (relative to PROJECT_ROOT)
EXCLUDE_DIRS=()

# LOC limits — branches/batches exceeding these are split automatically
MAX_LOC=3000
MAX_FIX_LOC=2000

# Claude model selection per stage (haiku | sonnet | opus)
AUDIT_MODEL="haiku"
FIX_MODEL="sonnet"
COMMIT_MODEL="haiku"

# Default CLI behavior — set these to avoid typing flags every time
# Run `bun config` to change interactively
DEFAULT_MODE="api"
DEFAULT_DIFF=false
DEFAULT_DIFF_REF=""
DEFAULT_FORCE_ALL=false
DEFAULT_DRY_RUN=false
DEFAULT_STDOUT=false
DEFAULT_INTERACTIVE=false
DEFAULT_SKIP_COMMITS=false
